import java.util.*;

class RoomBookingSystem {
    void bookRoom(String name) {
        System.out.println("Room booked for " + name);
    }
    void cancelRoom(String name) {
        System.out.println("Room canceled for " + name);
    }
}

class RestaurantSystem {
    void bookTable(String name) {
        System.out.println("Table booked for " + name);
    }
    void orderFood(String name) {
        System.out.println("Food ordered for " + name);
    }
}

class EventManagementSystem {
    void organizeEvent(String event) {
        System.out.println("Event organized: " + event);
    }
}

class CleaningService {
    void scheduleCleaning(String room) {
        System.out.println("Cleaning scheduled for " + room);
    }
}

class TaxiService {
    void callTaxi(String name) {
        System.out.println("Taxi called for " + name);
    }
}

class HotelFacade {
    private RoomBookingSystem room = new RoomBookingSystem();
    private RestaurantSystem restaurant = new RestaurantSystem();
    private EventManagementSystem event = new EventManagementSystem();
    private CleaningService cleaning = new CleaningService();
    private TaxiService taxi = new TaxiService();

    void bookRoomWithServices(String name) {
        room.bookRoom(name);
        restaurant.orderFood(name);
        cleaning.scheduleCleaning("Room of " + name);
    }

    void organizeEvent(String eventName, String guest) {
        event.organizeEvent(eventName);
        room.bookRoom(guest);
    }

    void bookTableWithTaxi(String name) {
        restaurant.bookTable(name);
        taxi.callTaxi(name);
    }

    void cancelBooking(String name) {
        room.cancelRoom(name);
    }
}

abstract class OrganizationComponent {
    void add(OrganizationComponent c) {}
    void remove(OrganizationComponent c) {}
    abstract double getSalary();
    abstract int getEmployeeCount();
    abstract void show();
}

class Employee extends OrganizationComponent {
    String name;
    String position;
    double salary;

    Employee(String name, String position, double salary) {
        this.name = name;
        this.position = position;
        this.salary = salary;
    }

    double getSalary() {
        return salary;
    }

    int getEmployeeCount() {
        return 1;
    }

    void show() {
        System.out.println(name + " " + position + " " + salary);
    }
}

class Department extends OrganizationComponent {
    String name;
    List<OrganizationComponent> list = new ArrayList<>();

    Department(String name) {
        this.name = name;
    }

    void add(OrganizationComponent c) {
        list.add(c);
    }

    void remove(OrganizationComponent c) {
        list.remove(c);
    }

    double getSalary() {
        double sum = 0;
        for (OrganizationComponent c : list)
            sum += c.getSalary();
        return sum;
    }

    int getEmployeeCount() {
        int count = 0;
        for (OrganizationComponent c : list)
            count += c.getEmployeeCount();
        return count;
    }

    void show() {
        System.out.println("Department: " + name);
        for (OrganizationComponent c : list)
            c.show();
    }
}

public class Main {
    public static void main(String[] args) {
        HotelFacade hotel = new HotelFacade();

        hotel.bookRoomWithServices("Ernur");
        hotel.organizeEvent("Conference", "Guests");
        hotel.bookTableWithTaxi("Ernur");
        hotel.cancelBooking("Ernur");

        Department company = new Department("Company");

        Department it = new Department("IT");
        Department hr = new Department("HR");

        Employee e1 = new Employee("A", "Dev", 1000);
        Employee e2 = new Employee("B", "Dev", 1200);
        Employee e3 = new Employee("C", "HR", 800);

        it.add(e1);
        it.add(e2);
        hr.add(e3);

        company.add(it);
        company.add(hr);

        company.show();

        System.out.println(company.getSalary());
        System.out.println(company.getEmployeeCount());
    }
}
